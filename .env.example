# Copy to .env and fill in your values

# Flask
SECRET_KEY=your_secret_key

# PostgreSQL
DB_USER=
DB_PASS=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=

# Email (Flask-Mail)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=

# Google Gemini (kept for /api/recommend)
GEMINI_API_KEY=

# Weather
WEATHER_API_KEY=

# Ollama (local — /api/chat and /api/recommend-ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
